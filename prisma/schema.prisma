generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model pr_story_paragraph {
  id                   Int                  @id @default(autoincrement())
  userId               Int                  @map("user_id")
  parentId             Int                  @default(0) @map("parent_id")
  likes                Int                  @default(0)
  dislikes             Int                  @default(0)
  paragraph            String               @db.VarChar(500)
  status               Int                  @default(1)
  ts                   DateTime             @default(now())
  crtAt                DateTime             @default(now()) @map("crt_at")
  crtBy                String               @map("crt_by") @db.VarChar(25)
  updAt                DateTime             @updatedAt @map("upd_at")
  updBy                String               @map("upd_by") @db.VarChar(25)
  users                pr_users?            @relation(fields: [userId], references: [userId], onDelete: Restrict, onUpdate: Restrict, map: "pr_story_paragraph_ibfk_1")
  childParagraph       pr_story_paragraph?  @relation("ChildParas", fields: [pr_story_paragraphId], references: [id])
  pr_story_paragraphId Int?
  childParagraphs      pr_story_paragraph[] @relation("ChildParas")

  @@index([userId], map: "user_id")
}

model pr_users {
  userId        Int                  @id @default(autoincrement()) @map("user_id")
  firstName     String               @map("first_name") @db.VarChar(100)
  lastName      String?              @map("last_name") @db.VarChar(100)
  mobile        String?              @db.VarChar(15)
  email         String?              @db.VarChar(255)
  role          String?              @db.VarChar(50)
  facebookLink  String?              @map("facebook_link") @db.VarChar(255)
  twitterLink   String?              @map("twitter_link") @db.VarChar(255)
  instagramLink String?              @map("instagram_link") @db.VarChar(255)
  status        Int                  @default(1)
  ts            DateTime             @default(now())
  crtAt         DateTime             @default(now()) @map("crt_at")
  crtBy         String               @map("crt_by") @db.VarChar(25)
  updAt         DateTime             @updatedAt @map("upd_at")
  updBy         String               @map("upd_by") @db.VarChar(25)
  paragraph     pr_story_paragraph[]
}
