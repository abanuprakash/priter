generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Story {
  id                Int      @id @default(autoincrement())
  userId            String
  userImage         String
  parentId          Int      @default(0) @map("parent_id")
  likes             Int      @default(0)
  dislikes          Int      @default(0)
  average           Int      @default(0)
  paragraph         String   @db.VarChar(500)
  title             String?  @db.VarChar(50)
  status            Int      @default(1)
  ts                DateTime @default(now())
  crtAt             DateTime @default(now()) @map("crt_at")
  crtBy             String   @map("crt_by") @db.VarChar(25)
  updAt             DateTime @updatedAt @map("upd_at")
  updBy             String   @map("upd_by") @db.VarChar(25)
  user              User     @relation(fields: [userId], references: [id])
  childParagraph    Story?   @relation("ChildParas", fields: [story_paragraphId], references: [id])
  story_paragraphId Int?
  childParagraphs   Story[]  @relation("ChildParas")
}

